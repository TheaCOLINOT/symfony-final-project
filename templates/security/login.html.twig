{% extends 'base.html.twig' %}

{% block title %}Connexion - Salon de Massage{% endblock %}

{% block body %}
<form method="post">
    {% if error %}
        <div style="color: red; margin-bottom: 15px;">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <h1>Connexion</h1>
    
    {# 1. Changement ici : name="_username" au lieu de name="email" #}
    <label for="inputEmail">Email</label>
    <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" required autofocus>

    {# 2. Changement ici : name="_password" au lieu de name="password" #}
    <label for="inputPassword">Mot de passe</label>
    <input type="password" name="_password" id="inputPassword" required>

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    <button type="submit" style="margin-top: 10px;">Se connecter</button>
</form>
<p>Pas encore de compte ? <a href="{{ path('app_register') }}">Inscrivez-vous</a></p>
{% endblock %}