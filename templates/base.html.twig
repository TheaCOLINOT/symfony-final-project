<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Salon de Massage{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>💆</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body>
        <nav style="padding: 15px 30px; background: #2c3e50; font-family: sans-serif;">
            <a href="{{ path('app_home') }}" style="color: white; text-decoration: none; margin-right: 20px;">Accueil</a>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin') }}" style="color: white; text-decoration: none; margin-right: 20px;">Administration</a>
            {% endif %}

            {% if is_granted('ROLE_MANAGER') %}
                <a href="{{ path('app_manager') }}" style="color: white; text-decoration: none; margin-right: 20px;">Espace manager</a>
            {% endif %}

            {% if is_granted('ROLE_CAT') %}
                <a href="{{ path('app_cat') }}" style="color: white; text-decoration: none; margin-right: 20px;">Espace chat</a>
            {% endif %}

            <span style="float: right;">
                {% if app.user %}
                    <span style="color: #ecf0f1; margin-right: 15px;">{{ app.user.firstname }} {{ app.user.name }}</span>
                    <a href="{{ path('app_logout') }}" style="color: #e74c3c; text-decoration: none;">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" style="color: white; text-decoration: none; margin-right: 15px;">Connexion</a>
                    <a href="{{ path('app_register') }}" style="color: white; text-decoration: none;">Inscription</a>
                {% endif %}
            </span>
        </nav>

        {% block body %}{% endblock %}
    </body>
</html>
