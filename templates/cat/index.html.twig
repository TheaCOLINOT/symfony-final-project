{% extends 'base.html.twig' %}

{% block title %}Espace masseur chat{% endblock %}

{% block body %}
<div class="dashboard">
    <h1>Espace masseur chat</h1>
    <p class="muted">Vous êtes masseur dans un salon de massage — en tant que chat.</p>

    {% if user %}
        <p>Bonjour <strong>{{ user.firstname }} {{ user.name }}</strong>.</p>
    {% endif %}

    {% if cat is null %}
        <div class="card">
            <h2>Créer mon profil masseur</h2>
            <p class="muted">Complétez votre fiche pour que les managers de salon puissent vous recruter.</p>
            {{ form_start(profile_form) }}
                {{ form_row(profile_form.specie) }}
                {{ form_row(profile_form.color) }}
                {{ form_row(profile_form.speciality) }}
                <button type="submit" class="btn-purple">Créer mon profil</button>
            {{ form_end(profile_form) }}
        </div>
    {% else %}
        <div class="card">
            <h2>Mon profil</h2>
            <p><strong>Spécialité :</strong> {{ cat.speciality }}</p>
            <p><strong>Espèce :</strong> {{ cat.specie }} · <strong>Couleur :</strong> {{ cat.color }}</p>
        </div>

        <div class="card">
            <h2>Mes salons de massage</h2>
            {% if cat.locations is empty %}
                <p class="muted">Vous n'êtes rattaché à aucun salon pour le moment. Un manager doit vous ajouter à son équipe avant que vous puissiez choisir vos prestations.</p>
            {% else %}
                <ul class="salon-list">
                    {% for location in cat.locations %}
                        <li><strong>{{ location.city }}</strong> — {{ location.address }}, {{ location.country }}</li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>

        {% if cat.locations is not empty %}
            <div class="card">
                <h2>Mon planning</h2>
                <p class="muted">Consultez vos réservations confirmées par semaine ou par mois.</p>
                <p>
                    <a href="{{ path('app_cat_planning', { view: 'week' }) }}" class="btn btn-purple" style="margin-right: 0.5rem;">Vue semaine</a>
                    <a href="{{ path('app_cat_planning', { view: 'month' }) }}" class="btn btn-secondary">Vue mois</a>
                </p>
            </div>

            <div class="card">
                <h2>Mes prestations</h2>
                <p class="muted">Choisissez les types de massage que vous proposez dans vos salons.</p>

                {% if available_services is empty %}
                    <p class="muted">Aucun service global n'est disponible pour le moment.</p>
                {% else %}
                    {{ form_start(service_form, { attr: { class: 'services-list' } }) }}
                        {{ form_widget(service_form.services) }}
                        <button type="submit" class="btn-purple">Enregistrer mes services</button>
                    {{ form_end(service_form) }}
                {% endif %}

                {% if cat.services is not empty %}
                    <p style="margin-top: 1.25rem;"><strong>Services actuellement sélectionnés :</strong></p>
                    {% for service in cat.services %}
                        <span class="badge">{{ service.title }} · {{ service.price }}€ · {{ service.duration }}</span>
                    {% endfor %}
                {% endif %}
            </div>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
