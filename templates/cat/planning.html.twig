{% extends 'base.html.twig' %}

{% block title %}Mon planning{% endblock %}

{% block stylesheets %}
<style>
    .page { max-width: 1100px; margin: 40px auto; font-family: sans-serif; padding: 0 20px; }
    .toolbar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .view-switch a { margin-right: 8px; padding: 8px 14px; border-radius: 8px; text-decoration: none; background: #ecf0f1; color: #2c3e50; }
    .view-switch a.active { background: #7c3aed; color: white; }
    .nav-period a { text-decoration: none; color: #2563eb; margin: 0 8px; }
    .card { background: #fff; border-radius: 12px; padding: 24px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
    .week-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 12px; }
    .day-column { border: 1px solid #e5e7eb; border-radius: 10px; padding: 12px; min-height: 180px; background: #fafafa; }
    .day-column h3 { margin: 0 0 12px; font-size: 0.95rem; color: #374151; }
    .booking { background: #ede9fe; border-left: 3px solid #7c3aed; padding: 10px; border-radius: 8px; margin-bottom: 10px; font-size: 0.9rem; }
    .booking-time { font-weight: 700; color: #5b21b6; }
    .month-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 8px; }
    .month-head { font-weight: 700; text-align: center; padding: 8px; color: #6b7280; }
    .month-cell { border: 1px solid #e5e7eb; border-radius: 8px; min-height: 110px; padding: 8px; background: #fff; }
    .month-cell.outside { background: #f9fafb; color: #9ca3af; }
    .month-day { font-weight: 700; margin-bottom: 6px; }
    .month-booking { background: #ede9fe; color: #5b21b6; border-radius: 6px; padding: 4px 6px; margin-bottom: 4px; font-size: 0.75rem; }
    .muted { color: #6b7280; }
    @media (max-width: 900px) { .week-grid, .month-grid { grid-template-columns: 1fr; } .month-head { display: none; } }
</style>
{% endblock %}

{% block body %}
<div class="page">
    <p><a href="{{ path('app_cat') }}">← Retour à mon espace</a></p>
    <h1>Mon planning de réservations</h1>
    <p class="muted">Consultez vos rendez-vous confirmés par semaine ou par mois.</p>

    <div class="toolbar">
        <div class="view-switch">
            <a href="{{ path('app_cat_planning', { view: 'week', date: current_date }) }}" class="{{ view == 'week' ? 'active' : '' }}">Semaine</a>
            <a href="{{ path('app_cat_planning', { view: 'month', date: current_date }) }}" class="{{ view == 'month' ? 'active' : '' }}">Mois</a>
        </div>
        <div class="nav-period">
            <a href="{{ path('app_cat_planning', { view: view, date: prev_date }) }}">← Précédent</a>
            <strong>{{ title }}</strong>
            <a href="{{ path('app_cat_planning', { view: view, date: next_date }) }}">Suivant →</a>
        </div>
    </div>

    <div class="card">
        {% if view == 'week' %}
            <div class="week-grid">
                {% for day in week_days %}
                    <div class="day-column">
                        <h3>{{ day.label }}</h3>
                        {% if day.reservations is empty %}
                            <p class="muted" style="font-size: 0.85rem;">Aucun rendez-vous</p>
                        {% else %}
                            {% for reservation in day.reservations %}
                                <div class="booking">
                                    <div class="booking-time">{{ reservation.reservationDate|date('H:i') }}</div>
                                    <div>{{ reservation.serviceLabel }}</div>
                                    <div class="muted">{{ reservation.location.city }}</div>
                                    <div class="muted">{{ reservation.user.firstname }} {{ reservation.user.name }}</div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="month-grid">
                <div class="month-head">Lun</div>
                <div class="month-head">Mar</div>
                <div class="month-head">Mer</div>
                <div class="month-head">Jeu</div>
                <div class="month-head">Ven</div>
                <div class="month-head">Sam</div>
                <div class="month-head">Dim</div>
                {% for cell in month_grid %}
                    <div class="month-cell {{ cell.inMonth ? '' : 'outside' }}">
                        <div class="month-day">{{ cell.date|date('d') }}</div>
                        {% for reservation in cell.reservations %}
                            <div class="month-booking">
                                {{ reservation.reservationDate|date('H:i') }} — {{ reservation.serviceLabel|slice(0, 18) }}
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
