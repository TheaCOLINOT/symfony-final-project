{% extends 'base.html.twig' %}

{% block title %}Mon planning{% endblock %}

{% block body %}
<div class="page">
    <p class="link-back"><a href="{{ path('app_cat') }}">← Retour à mon espace</a></p>
    <h1>Mon planning de réservations</h1>
    <p class="muted">Consultez vos rendez-vous confirmés par semaine ou par mois.</p>

    <div class="toolbar">
        <div class="view-switch">
            <a href="{{ path('app_cat_planning', { view: 'week', date: current_date }) }}" class="{{ view == 'week' ? 'active' : '' }}">Semaine</a>
            <a href="{{ path('app_cat_planning', { view: 'month', date: current_date }) }}" class="{{ view == 'month' ? 'active' : '' }}">Mois</a>
        </div>
        <div class="nav-period">
            <a href="{{ path('app_cat_planning', { view: view, date: prev_date }) }}">← Précédent</a>
            <strong>{{ title }}</strong>
            <a href="{{ path('app_cat_planning', { view: view, date: next_date }) }}">Suivant →</a>
        </div>
    </div>

    <div class="card">
        {% if view == 'week' %}
            <div class="week-grid">
                {% for day in week_days %}
                    <div class="day-column">
                        <h3>{{ day.label }}</h3>
                        {% if day.reservations is empty %}
                            <p class="muted" style="font-size: 0.85rem;">Aucun rendez-vous</p>
                        {% else %}
                            {% for reservation in day.reservations %}
                                <div class="booking">
                                    <div class="booking-time">{{ reservation.reservationDate|date('H:i') }}</div>
                                    <div>{{ reservation.serviceLabel }}</div>
                                    <div class="muted">{{ reservation.location.city }}</div>
                                    <div class="muted">{{ reservation.user.firstname }} {{ reservation.user.name }}</div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="month-grid">
                <div class="month-head">Lun</div>
                <div class="month-head">Mar</div>
                <div class="month-head">Mer</div>
                <div class="month-head">Jeu</div>
                <div class="month-head">Ven</div>
                <div class="month-head">Sam</div>
                <div class="month-head">Dim</div>
                {% for cell in month_grid %}
                    <div class="month-cell {{ cell.inMonth ? '' : 'outside' }}">
                        <div class="month-day">{{ cell.date|date('d') }}</div>
                        {% for reservation in cell.reservations %}
                            <div class="month-booking">
                                {{ reservation.reservationDate|date('H:i') }} — {{ reservation.serviceLabel|slice(0, 18) }}
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
