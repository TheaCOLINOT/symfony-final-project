{% extends 'base.html.twig' %}

{% block title %}Espace manager{% endblock %}

{% block body %}
<div class="dashboard">
    <h1>Espace manager de salon</h1>
    <p class="muted">Gérez votre salon de massage et votre équipe de masseurs chats.</p>

    {% if user %}
        <p>Bonjour <strong>{{ user.firstname }} {{ user.name }}</strong>.</p>
    {% endif %}

    {% if no_location %}
        <div class="card">
            <p class="muted">Aucun salon ne vous est encore assigné. Contactez un administrateur global pour obtenir une localisation.</p>
        </div>
    {% else %}
        <div class="salon-badge">
            {% if is_global_admin %}
                Localisation globale — accès administration
            {% else %}
                Salon : <strong>{{ managed_location.city }}</strong> — {{ managed_location.address }}
            {% endif %}
        </div>

        {% if is_global_admin %}
            <div class="card">
                <p>En tant que manager de la localisation globale, utilisez l'<a href="{{ path('app_admin') }}">interface d'administration</a> pour créer des villes et assigner des managers.</p>
                <p class="muted">Depuis cet espace, vous pouvez gérer les services globaux de la plateforme.</p>
            </div>
        {% endif %}

        <div class="grid">
            <section class="card">
                <h2>Créer une prestation</h2>
                <p class="muted">Catalogue des types de massage proposés dans tous les salons.</p>
                {{ form_start(service_form) }}
                    {{ form_row(service_form.title) }}
                    {{ form_row(service_form.description) }}
                    {{ form_row(service_form.duration) }}
                    {{ form_row(service_form.price) }}
                    <button type="submit">Créer le service</button>
                {{ form_end(service_form) }}
            </section>

            {% if not is_global_admin and add_cat_form %}
                <section class="card">
                    <h2>Recruter un masseur chat</h2>
                    <p class="muted">Ajoutez un masseur chat déjà inscrit sur la plateforme. Votre salon peut en accueillir autant que nécessaire.</p>
                    {% if available_masseurs_count > 0 %}
                        {{ form_start(add_cat_form) }}
                            {{ form_row(add_cat_form.masseurUser) }}
                            <button type="submit">Ajouter au salon</button>
                        {{ form_end(add_cat_form) }}
                    {% else %}
                        <p class="muted">Aucun masseur chat inscrit disponible. Les masseurs doivent s'inscrire sur la plateforme et recevoir le rôle « Chat masseur » depuis l'administration.</p>
                    {% endif %}
                </section>
            {% endif %}

            <section class="card">
                <h2>Catalogue des prestations</h2>
                {% if services is empty %}
                    <p class="muted">Aucun service global n'a encore été créé.</p>
                {% else %}
                    <ul class="list">
                        {% for service in services %}
                            <li>
                                <strong>{{ service.title }}</strong> — {{ service.price }}€ ({{ service.duration }})<br>
                                <span class="muted">{{ service.description }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>
        </div>

        {% if not is_global_admin %}
            <h2 style="margin-top: 2rem;">Masseurs chats de votre salon</h2>
            {% if cats is empty %}
                <div class="card">
                    <p class="muted">Aucun masseur chat n'a encore rejoint votre salon.</p>
                </div>
            {% else %}
                {% for cat in cats %}
                    <div class="card cat-card">
                        <h3>{{ cat.speciality }}</h3>
                        <p><strong>Espèce :</strong> {{ cat.specie }} · <strong>Couleur :</strong> {{ cat.color }}</p>
                        {% if cat.user %}
                            <p class="muted">Compte : {{ cat.user.firstname }} {{ cat.user.name }} ({{ cat.user.email }})</p>
                        {% endif %}
                        {% if cat.locations|length > 1 %}
                            <p class="muted">Présent aussi dans {{ cat.locations|length - 1 }} autre(s) salon(s).</p>
                        {% endif %}
                        <p class="muted">Ce masseur choisit lui-même ses prestations depuis son espace personnel.</p>
                    </div>
                {% endfor %}
            {% endif %}
        {% endif %}
    {% endif %}
</div>
{% endblock %}
