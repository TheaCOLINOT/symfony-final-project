{% extends 'email/base.html.twig' %}

{% block title %}Confirmez votre inscription{% endblock %}

{% block content %}
    <h1 style="color: #2c3e50;">Bonjour {{ user.firstname }} !</h1>

    <p>Merci de vous être inscrit sur <strong>Salon de Massage</strong>.</p>

    <p>Pour activer votre compte et vous connecter, confirmez votre adresse e-mail en cliquant sur le bouton ci-dessous :</p>

    <p style="margin: 24px 0;">
        <a href="{{ verificationUrl }}" style="background: #0d9488; color: #fff; padding: 12px 20px; text-decoration: none; border-radius: 6px; font-weight: 600;">
            Confirmer mon inscription
        </a>
    </p>

    <p style="color: #64748b; font-size: 14px;">
        Ce lien est valable 48 heures. Si vous n'êtes pas à l'origine de cette inscription, ignorez cet e-mail.
    </p>

    <p style="color: #64748b; font-size: 13px; word-break: break-all;">
        Lien direct : {{ verificationUrl }}
    </p>
{% endblock %}
