{% extends 'email/base.html.twig' %}

{% block title %}Confirmation de réservation{% endblock %}

{% block content %}
    <h1 style="color: #2c3e50;">Réservation confirmée</h1>

    <p>Bonjour {{ reservation.user.firstname }},</p>

    <p>Votre réservation a bien été enregistrée. Voici le récapitulatif :</p>

    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <tr>
            <td style="padding: 8px 0; color: #7f8c8d;">Prestation</td>
            <td style="padding: 8px 0;"><strong>{{ reservation.serviceLabel }}</strong></td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #7f8c8d;">Masseur chat</td>
            <td style="padding: 8px 0;"><strong>{{ reservation.catLabel }}</strong></td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #7f8c8d;">Lieu</td>
            <td style="padding: 8px 0;"><strong>{{ reservation.location.city }} — {{ reservation.location.address }}</strong></td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #7f8c8d;">Date</td>
            <td style="padding: 8px 0;"><strong>{{ reservation.reservationDate|date('d/m/Y à H:i') }}</strong></td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #7f8c8d;">Durée</td>
            <td style="padding: 8px 0;"><strong>{{ reservation.duration }}</strong></td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #7f8c8d;">Prix</td>
            <td style="padding: 8px 0;"><strong>{{ reservation.price }} €</strong></td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #7f8c8d;">Référence</td>
            <td style="padding: 8px 0;"><strong>#{{ reservation.id }}</strong></td>
        </tr>
    </table>

    <p>
        <a href="{{ url('app_user_reservations') }}" style="background: #2c3e50; color: #fff; padding: 10px 16px; text-decoration: none; border-radius: 4px;">
            Voir mes réservations
        </a>
    </p>
{% endblock %}
