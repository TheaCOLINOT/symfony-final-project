{% extends 'base.html.twig' %}

{% block title %}Accueil - Salon de Massage{% endblock %}

{% block body %}
<div class="home">
    <h1>Bienvenue au Salon de Massage</h1>

    {% if user %}
        <p>Bonjour <strong>{{ user.firstname }} {{ user.name }}</strong>.</p>
        <p class="muted">Email : {{ user.email }} · Rôle : {{ user.userRole ? user.userRole.label : 'Utilisateur standard' }}</p>

        {% if is_granted('ROLE_USER') and not is_granted('ROLE_MANAGER') and not is_granted('ROLE_CAT') %}
            <p>
                <a href="{{ path('app_search') }}" class="btn btn-primary">Rechercher une prestation</a>
                <a href="{{ path('app_user_reservations') }}" class="btn btn-secondary">Mes réservations</a>
            </p>

            <div class="card">
                <h2>Prochaines réservations</h2>
                {% if upcoming_reservations is empty %}
                    <p class="muted">Vous n'avez pas encore de rendez-vous planifié.</p>
                {% else %}
                    {% for reservation in upcoming_reservations %}
                        <div class="reservation-preview">
                            <strong>{{ reservation.reservationDate|date('d/m/Y à H:i') }}</strong> — {{ reservation.serviceLabel }}<br>
                            <span class="muted">{{ reservation.location.city }} · {{ reservation.catLabel }}</span>
                        </div>
                    {% endfor %}
                    <a href="{{ path('app_user_reservations') }}" class="see-all">Voir toutes mes réservations →</a>
                {% endif %}
            </div>
        {% endif %}

        {% if is_granted('ROLE_MANAGER') %}
            <p><a href="{{ path('app_manager') }}" class="btn btn-secondary">Accéder à l'espace manager</a></p>
        {% endif %}

        {% if is_granted('GLOBAL_ADMIN') %}
            <p><a href="{{ path('app_admin') }}" class="btn btn-secondary">Accéder à l'administration</a></p>
        {% endif %}

        {% if is_granted('ROLE_CAT') %}
            <p><a href="{{ path('app_cat') }}" class="btn btn-purple">Accéder à l'espace masseur chat</a></p>
        {% endif %}
    {% else %}
        <div class="card">
            <p>Vous n'êtes pas connecté.</p>
            <p>
                <a href="{{ path('app_login') }}" class="btn btn-primary">Se connecter</a>
                <a href="{{ path('app_register') }}" class="btn btn-secondary">Créer un compte</a>
            </p>
        </div>
    {% endif %}
</div>
{% endblock %}
