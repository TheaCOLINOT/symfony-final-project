{% extends 'base.html.twig' %}

{% block title %}Gestion des salons{% endblock %}

{% block body %}
<div class="admin-wrapper">
    <h1>Gestion des villes et salons</h1>
    <p class="link-back"><a href="{{ path('app_admin') }}">← Retour au tableau de bord</a></p>

    {% if globalLocation %}
        <div class="card">
            <h2>Localisation globale</h2>
            <p>
                <span class="badge-global">Global</span>
                {{ globalLocation.address }} — {{ globalLocation.country }}
            </p>
            <p><strong>Managers globaux :</strong></p>
            <ul>
                {% for manager in globalLocation.managers %}
                    {% if manager.user %}
                        <li>{{ manager.user.firstname }} {{ manager.user.name }} ({{ manager.user.email }})</li>
                    {% endif %}
                {% else %}
                    <li class="muted">Aucun manager global assigné.</li>
                {% endfor %}
            </ul>
            <p class="muted">Tous les managers de cette localisation ont accès à l'interface admin.</p>

            {% if availableGlobalManagers is not empty %}
                <form method="post" action="{{ path('app_admin_global_manager_add') }}" style="margin-top: 1rem;">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_global_manager') }}">
                    <label for="manager_user_id">Ajouter un manager global</label>
                    <select name="manager_user_id" id="manager_user_id">
                        {% for user in availableGlobalManagers %}
                            <option value="{{ user.id }}">{{ user.firstname }} {{ user.name }} ({{ user.email }})</option>
                        {% endfor %}
                    </select>
                    <button type="submit">Ajouter</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    <div class="card">
        <h2>Créer un salon par ville</h2>
        <p class="muted">Chaque ville doit avoir un manager responsable.</p>
        {{ form_start(form) }}
            {{ form_row(form.city) }}
            {{ form_row(form.address) }}
            {{ form_row(form.country) }}
            {{ form_row(form.managerUser) }}
            <button type="submit">Créer le salon</button>
        {{ form_end(form) }}
    </div>

    <div class="card">
        <h2>Salons existants</h2>
        {% if locations is empty %}
            <p class="muted">Aucun salon n'a encore été créé.</p>
        {% else %}
            <table class="locations-table">
                <thead>
                    <tr>
                        <th>Ville</th>
                        <th>Adresse</th>
                        <th>Manager</th>
                        <th>Masseurs chats</th>
                        <th>Type</th>
                    </tr>
                </thead>
                <tbody>
                    {% for location in locations %}
                        <tr>
                            <td><strong>{{ location.city }}</strong></td>
                            <td>{{ location.address }}, {{ location.country }}</td>
                            <td>
                                {% if location.managers is not empty %}
                                    {% for manager in location.managers %}
                                        {% if manager.user %}
                                            {{ manager.user.firstname }} {{ manager.user.name }}{% if not loop.last %}, {% endif %}
                                        {% endif %}
                                    {% endfor %}
                                {% else %}
                                    <span class="muted">Non assigné</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if location.isGlobal %}
                                    <span class="muted">—</span>
                                {% elseif location.cats is empty %}
                                    <span class="muted">Aucun</span>
                                {% else %}
                                    {{ location.cats|length }} masseur{{ location.cats|length > 1 ? 's' : '' }} chat
                                {% endif %}
                            </td>
                            <td>
                                {% if location.isGlobal %}
                                    <span class="badge-global">Global</span>
                                {% else %}
                                    Salon
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
