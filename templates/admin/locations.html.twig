{% extends 'base.html.twig' %}

{% block title %}Gestion des salons{% endblock %}

{% block stylesheets %}
<style>
    .admin-wrapper { max-width: 1000px; margin: 40px auto; font-family: sans-serif; padding: 0 20px; }
    .card { background: #fff; border-radius: 12px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 24px; }
    .flash { padding: 12px 16px; border-radius: 6px; margin-bottom: 20px; }
    .flash-success { background: #d4edda; color: #155724; }
    .flash-error { background: #f8d7da; color: #721c24; }
    .locations-table { width: 100%; border-collapse: collapse; }
    .locations-table th, .locations-table td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
    .locations-table th { background: #2c3e50; color: white; }
    .badge-global { background: #e74c3c; color: white; padding: 4px 10px; border-radius: 12px; font-size: 0.85em; }
    form > div { margin-bottom: 14px; }
    input { width: 100%; padding: 10px; border: 1px solid #d1d5db; border-radius: 8px; box-sizing: border-box; }
    button { background: #27ae60; color: white; border: none; padding: 10px 16px; border-radius: 8px; cursor: pointer; }
</style>
{% endblock %}

{% block body %}
<div class="admin-wrapper">
    <h1>Gestion des villes et salons</h1>
    <p><a href="{{ path('app_admin') }}">← Retour au tableau de bord</a></p>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if globalLocation %}
        <div class="card">
            <h2>Localisation globale</h2>
            <p>
                <span class="badge-global">Global</span>
                {{ globalLocation.address }} — {{ globalLocation.country }}
            </p>
            <p><strong>Managers globaux :</strong></p>
            <ul>
                {% for manager in globalLocation.managers %}
                    {% if manager.user %}
                        <li>{{ manager.user.firstname }} {{ manager.user.name }} ({{ manager.user.email }})</li>
                    {% endif %}
                {% else %}
                    <li class="muted">Aucun manager global assigné.</li>
                {% endfor %}
            </ul>
            <p class="muted">Tous les managers de cette localisation ont accès à l'interface admin.</p>

            {% if availableGlobalManagers is not empty %}
                <form method="post" action="{{ path('app_admin_global_manager_add') }}" style="margin-top: 16px;">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_global_manager') }}">
                    <label for="manager_user_id">Ajouter un manager global</label>
                    <select name="manager_user_id" id="manager_user_id" style="width: 100%; padding: 10px; margin: 8px 0;">
                        {% for user in availableGlobalManagers %}
                            <option value="{{ user.id }}">{{ user.firstname }} {{ user.name }} ({{ user.email }})</option>
                        {% endfor %}
                    </select>
                    <button type="submit">Ajouter</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    <div class="card">
        <h2>Créer un salon par ville</h2>
        <p class="muted">Chaque ville doit avoir un manager responsable.</p>
        {{ form_start(form) }}
            {{ form_row(form.city) }}
            {{ form_row(form.address) }}
            {{ form_row(form.country) }}
            {{ form_row(form.managerUser) }}
            <button type="submit">Créer le salon</button>
        {{ form_end(form) }}
    </div>

    <div class="card">
        <h2>Salons existants</h2>
        {% if locations is empty %}
            <p class="muted">Aucun salon n'a encore été créé.</p>
        {% else %}
            <table class="locations-table">
                <thead>
                    <tr>
                        <th>Ville</th>
                        <th>Adresse</th>
                        <th>Manager</th>
                        <th>Masseurs chats</th>
                        <th>Type</th>
                    </tr>
                </thead>
                <tbody>
                    {% for location in locations %}
                        <tr>
                            <td><strong>{{ location.city }}</strong></td>
                            <td>{{ location.address }}, {{ location.country }}</td>
                            <td>
                                {% if location.managers is not empty %}
                                    {% for manager in location.managers %}
                                        {% if manager.user %}
                                            {{ manager.user.firstname }} {{ manager.user.name }}{% if not loop.last %}, {% endif %}
                                        {% endif %}
                                    {% endfor %}
                                {% else %}
                                    <span class="muted">Non assigné</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if location.isGlobal %}
                                    <span class="muted">—</span>
                                {% elseif location.cats is empty %}
                                    <span class="muted">Aucun</span>
                                {% else %}
                                    {{ location.cats|length }} masseur{{ location.cats|length > 1 ? 's' : '' }} chat
                                {% endif %}
                            </td>
                            <td>
                                {% if location.isGlobal %}
                                    <span class="badge-global">Global</span>
                                {% else %}
                                    Salon
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
