{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}
<div class="page">
    <h1>Administration globale</h1>

    {% if user %}
        <p>Bonjour <strong>{{ user.firstname }} {{ user.name }}</strong>.</p>
        <p class="muted">Vous gérez la plateforme depuis la localisation globale.</p>
    {% endif %}

    <div class="admin-panel">
        <h2>Gestion des utilisateurs</h2>
        <p>Consultez la liste des utilisateurs inscrits et modifiez leurs rôles.</p>
        <a href="{{ path('app_admin_users') }}" class="btn btn-admin">
            Gérer les rôles des utilisateurs
        </a>
    </div>

    <div class="admin-panel">
        <h2>Gestion des villes et salons</h2>
        <p>Créez une localisation par ville et assignez un manager responsable.</p>
        <a href="{{ path('app_admin_locations') }}" class="btn btn-admin-green">
            Gérer les salons par ville
        </a>
    </div>

    <p class="link-back"><a href="{{ path('app_home') }}">Retour à l'accueil</a></p>
</div>
{% endblock %}
