{% extends 'base.html.twig' %}

{% block title %}Rechercher une prestation{% endblock %}

{% block body %}
    <div class="search-page">
        <h1>Trouver une prestation</h1>
        <p class="muted">Recherchez un massage par centre, par type de prestation ou via la barre de recherche.</p>

        <div class="search-card">
            {{ form_start(form, { attr: { class: 'filters' } }) }}
                <div>
                    {{ form_label(form.location) }}
                    {{ form_widget(form.location) }}
                </div>
                <div>
                    {{ form_label(form.service) }}
                    {{ form_widget(form.service) }}
                </div>
                <div class="full-width">
                    {{ form_label(form.q) }}
                    {{ form_widget(form.q) }}
                </div>
                <div class="full-width">
                    {{ form_widget(form.submit) }}
                    {% if has_filters %}
                        <a href="{{ path('app_search') }}" class="reset-link">Réinitialiser</a>
                    {% endif %}
                </div>
            {{ form_end(form) }}
        </div>

        <p class="result-count">
            <strong>{{ offers|length }}</strong> prestation{{ offers|length > 1 ? 's' : '' }} disponible{{ offers|length > 1 ? 's' : '' }}
            {% if has_filters %} correspondant à vos critères{% endif %}
        </p>

        {% if offers is empty %}
            <div class="search-card">
                <p class="muted">Aucune prestation trouvée. Essayez d'élargir vos critères ou vérifiez qu'un masseur chat propose bien des soins dans un salon.</p>
            </div>
        {% else %}
            <div class="results-grid">
                {% for offer in offers %}
                    <article class="offer-card{% if offer.service.isRemoteLiveChat %} offer-card--remote{% endif %}">
                        <h3>{{ offer.service.title }}</h3>
                        <p class="offer-price">{{ offer.service.price }}€ · {{ offer.service.duration }}</p>
                        <p>{{ offer.service.description }}</p>
                        <p class="offer-meta">
                            <strong>Centre :</strong>
                            {% if offer.location.isRemote %}
                                {{ offer.location.city }} — {{ offer.location.address }}
                            {% else %}
                                {{ offer.location.city }} — {{ offer.location.address }}, {{ offer.location.country }}
                            {% endif %}
                        </p>
                        <p class="offer-meta">
                            <strong>Masseur chat :</strong> {{ offer.cat.speciality }}
                            ({{ offer.cat.specie }}, {{ offer.cat.color }})
                        </p>
                        {% if offer.service.isRemoteLiveChat %}
                            <span class="badge">À distance · Live chat</span>
                        {% else %}
                            <span class="badge">Disponible à la réservation</span>
                        {% endif %}
                        <p style="margin-top: 1rem;">
                            {% if offer.service.isRemoteLiveChat %}
                                <a href="{{ path('app_reservation_book_remote', {
                                    serviceId: offer.service.id,
                                    catId: offer.cat.id
                                }) }}" class="btn btn-purple">Démarrer le live chat</a>
                            {% else %}
                                <a href="{{ path('app_reservation_book', {
                                    serviceId: offer.service.id,
                                    locationId: offer.location.id,
                                    catId: offer.cat.id
                                }) }}" class="btn btn-primary">Réserver</a>
                            {% endif %}
                        </p>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
