{% extends 'base.html.twig' %}

{% block title %}Live chat — {{ reservation.serviceLabel }}{% endblock %}

{% block body %}
<div class="chat-page">
    <p class="link-back"><a href="{{ path('app_user_reservations') }}">← Mes réservations</a></p>

    <div class="chat-header">
        <h1>Live chat avec {{ cat ? cat.speciality : reservation.catLabel }}</h1>
        <p class="muted">
            {{ reservation.serviceLabel }} · à distance
            {% if cat %}({{ cat.specie }}, {{ cat.color }}){% endif %}
        </p>
        <p class="muted">Le masseur chat répond automatiquement… comme s'il posait ses pattes sur le clavier.</p>
    </div>

    <div class="chat-box">
        <div id="chat-messages" class="chat-messages">
            {% for message in messages %}
                <div class="message {{ message.sender }}">
                    <div class="bubble">
                        {{ message.content|e }}
                        <time>{{ message.createdAt|date('H:i') }}</time>
                    </div>
                </div>
            {% else %}
                <p class="muted" id="chat-empty">Envoyez un message pour démarrer la conversation avec le chat.</p>
            {% endfor %}
        </div>
        <p class="typing" id="chat-typing">Le chat tape sur le clavier…</p>
        <form id="chat-form" class="chat-form" action="{{ path('app_live_chat_message', { reservationId: reservation.id }) }}" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('live_chat_message') }}">
            <input type="text" name="content" id="chat-input" placeholder="Écrivez votre message…" autocomplete="off" required maxlength="500">
            <button type="submit">Envoyer</button>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    const form = document.getElementById('chat-form');
    const input = document.getElementById('chat-input');
    const messagesEl = document.getElementById('chat-messages');
    const typingEl = document.getElementById('chat-typing');
    const emptyEl = document.getElementById('chat-empty');

    function appendMessage(sender, content, createdAt) {
        if (emptyEl) {
            emptyEl.remove();
        }

        const wrapper = document.createElement('div');
        wrapper.className = 'message ' + sender;

        const bubble = document.createElement('div');
        bubble.className = 'bubble';
        bubble.textContent = content;

        const time = document.createElement('time');
        time.textContent = createdAt;
        bubble.appendChild(time);

        wrapper.appendChild(bubble);
        messagesEl.appendChild(wrapper);
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    form.addEventListener('submit', async function (event) {
        event.preventDefault();

        const content = input.value.trim();
        if (content === '') {
            return;
        }

        const formData = new FormData(form);
        formData.set('content', content);
        input.value = '';

        const heure = new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
        appendMessage('user', content, heure);

        input.disabled = true;
        typingEl.style.display = 'block';

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
            });

            const data = await response.json();
            if (!response.ok) {
                alert(data.error || 'Impossible d\'envoyer le message.');
                return;
            }

            let catMessage = null;
            for (let i = 0; i < data.messages.length; i++) {
                if (data.messages[i].sender === 'cat') {
                    catMessage = data.messages[i];
                    break;
                }
            }

            if (catMessage) {
                await new Promise(function (resolve) {
                    setTimeout(resolve, 600);
                });
                appendMessage(catMessage.sender, catMessage.content, catMessage.createdAt);
            }
        } catch (error) {
            alert('Erreur réseau, réessayez.');
        } finally {
            typingEl.style.display = 'none';
            input.disabled = false;
            input.focus();
        }
    });
})();
</script>
{% endblock %}
