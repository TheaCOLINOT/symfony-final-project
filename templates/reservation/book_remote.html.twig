{% extends 'base.html.twig' %}

{% block title %}Live chat — {{ service.title }}{% endblock %}

{% block stylesheets %}
<style>
    .page { max-width: 720px; margin: 40px auto; font-family: sans-serif; padding: 0 20px; }
    .card { background: #fff; border-radius: 12px; padding: 24px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); margin-bottom: 20px; }
    .muted { color: #6b7280; }
    .price { color: #27ae60; font-weight: 700; font-size: 1.1rem; }
    .badge { display: inline-block; background: #ede9fe; color: #5b21b6; padding: 4px 10px; border-radius: 999px; font-size: 0.85rem; margin-top: 8px; }
    .btn-confirm { background: #9b59b6; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-size: 1rem; }
</style>
{% endblock %}

{% block body %}
<div class="page">
    <p><a href="{{ path('app_search') }}">← Retour à la recherche</a></p>
    <h1>Live chat à distance</h1>

    <div class="card">
        <h2>{{ service.title }}</h2>
        <p class="price">{{ service.price }}€ · {{ service.duration }}</p>
        <p>{{ service.description }}</p>
        <span class="badge">À distance · immédiat</span>
        <p class="muted" style="margin-top: 16px;"><strong>Lieu :</strong> {{ location.city }} ({{ location.address }})</p>
        <p class="muted"><strong>Masseur chat :</strong> {{ cat.speciality }} ({{ cat.specie }}, {{ cat.color }})</p>
    </div>

    <div class="card">
        <p>Cette prestation démarre tout de suite : vous serez redirigé vers le live chat après confirmation.</p>
        <form method="post" action="{{ path('app_reservation_confirm_remote') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('reservation_confirm_remote') }}">
            <input type="hidden" name="service_id" value="{{ service.id }}">
            <input type="hidden" name="cat_id" value="{{ cat.id }}">
            <button type="submit" class="btn-confirm">Confirmer et ouvrir le live chat</button>
        </form>
    </div>
</div>
{% endblock %}
