<article class="reservation-card">
    <div class="reservation-date">
        <strong>{{ reservation.reservationDate|date('d/m/Y') }}</strong>
        <span>{{ reservation.reservationDate|date('H:i') }}</span>
    </div>
    <div class="reservation-details">
        <h3>{{ reservation.serviceLabel }}</h3>
        <p class="muted">{{ reservation.duration }} · {{ reservation.price }}€</p>
        <p>
            <strong>Centre :</strong>
            {% if reservation.location.isRemote %}
                {{ reservation.location.city }} — {{ reservation.location.address }}
            {% else %}
                {{ reservation.location.city }} — {{ reservation.location.address }}
            {% endif %}
        </p>
        <p><strong>Masseur chat :</strong> {{ reservation.catLabel }}</p>
        {% if reservation.service and reservation.service.isRemoteLiveChat %}
            <p style="margin-top: 12px;">
                <a href="{{ path('app_live_chat', { reservationId: reservation.id }) }}" style="display: inline-block; background: #9b59b6; color: white; padding: 8px 14px; border-radius: 8px; text-decoration: none;">Ouvrir le live chat</a>
            </p>
        {% endif %}
    </div>
</article>
