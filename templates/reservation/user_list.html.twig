{% extends 'base.html.twig' %}

{% block title %}Mes réservations{% endblock %}

{% block body %}
<div class="page">
    <h1>Mes réservations</h1>
    <p class="muted">Consultez vos rendez-vous à venir et votre historique.</p>

    <div class="actions">
        <a href="{{ path('app_search') }}" class="btn btn-primary">Réserver une prestation</a>
    </div>

    <section class="section">
        <h2>Prochaines réservations</h2>
        {% if upcoming_reservations is empty %}
            <div class="empty">Aucune réservation à venir.</div>
        {% else %}
            {% for reservation in upcoming_reservations %}
                {% include 'reservation/_card.html.twig' with { reservation: reservation } %}
            {% endfor %}
        {% endif %}
    </section>

    <section class="section past">
        <h2>Réservations passées</h2>
        {% if past_reservations is empty %}
            <div class="empty">Aucune réservation passée.</div>
        {% else %}
            {% for reservation in past_reservations %}
                {% include 'reservation/_card.html.twig' with { reservation: reservation } %}
            {% endfor %}
        {% endif %}
    </section>
</div>
{% endblock %}
